{
  "_comment": "Request bodies for the Application Signals Dynamic Instrumentation control plane, used by .github/workflows/test.yml. Placeholders: \"$VAR\" -> replaced with os.environ['VAR'] as a string; \"$INT:VAR\" -> replaced as an integer (used for ExpiresAt which must be epoch seconds). Substitution happens via the inline Python snippet in the workflow steps that source this file.",

  "createBreakpoint": {
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "Location": {
      "CodeLocation": {
        "Language": "Python",
        "FilePath": "/home/ec2-user/django_frontend_service/frontend_service_app/views.py",
        "LineNumber": 134,
        "CodeUnit": "frontend_service_app.views",
        "MethodName": "http_call"
      }
    },
    "CaptureConfiguration": {
      "CodeCapture": {
        "CaptureArguments": [],
        "CaptureLocals": ["status_code", "response", "url"],
        "CaptureReturn": false,
        "CaptureStackTrace": true,
        "CaptureLimits": { "MaxHits": 100, "MaxStringLength": 128, "MaxCollectionSize": 10, "MaxFieldsPerObject": 10 }
      }
    },
    "Description": "DI E2E line-level breakpoint",
    "ExpiresAt": "$INT:EXPIRES_AT"
  },

  "createProbe": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "Location": {
      "CodeLocation": {
        "Language": "Python",
        "FilePath": "/home/ec2-user/django_frontend_service/frontend_service_app/views.py",
        "CodeUnit": "frontend_service_app.views",
        "MethodName": "aws_sdk_call"
      }
    },
    "CaptureConfiguration": {
      "CodeCapture": {
        "CaptureArguments": ["request"],
        "CaptureLocals": [],
        "CaptureReturn": true,
        "CaptureStackTrace": true,
        "CaptureLimits": { "MaxHits": 100, "MaxStringLength": 128, "MaxCollectionSize": 10, "MaxFieldsPerObject": 10 }
      }
    },
    "Description": "DI E2E function-level probe"
  },

  "createExceptionProbe": {
    "_comment": "Targets views.mysql, which raises KeyError uncaught when RDS_MYSQL_CLUSTER_PASSWORD is unset (the DI test env never sets it). Validates that PROBE snapshots fire on the exception-tail path: 3.10 SETUP_WITH/WITH_EXCEPT_START, 3.11 disjoint TryBegin/TryEnd, 3.12 sys.monitoring PY_RETURN with exception.",
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "Location": {
      "CodeLocation": {
        "Language": "Python",
        "FilePath": "/home/ec2-user/django_frontend_service/frontend_service_app/views.py",
        "CodeUnit": "frontend_service_app.views",
        "MethodName": "mysql"
      }
    },
    "CaptureConfiguration": {
      "CodeCapture": {
        "CaptureArguments": ["request"],
        "CaptureLocals": [],
        "CaptureReturn": false,
        "CaptureStackTrace": true,
        "CaptureLimits": { "MaxHits": 100, "MaxStringLength": 128, "MaxCollectionSize": 10, "MaxFieldsPerObject": 10 }
      }
    },
    "Description": "DI E2E exception-path PROBE on views.mysql"
  },

  "getBreakpoint": {
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "getProbe": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "getExceptionProbe": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "deleteBreakpoint": {
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "deleteProbe": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "deleteExceptionProbe": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  }
}
