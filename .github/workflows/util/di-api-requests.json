{
  "_comment": "Request bodies for the Application Signals Dynamic Instrumentation control plane, used by .github/workflows/test.yml. Naming convention: create<Level><Type>[Exception]. 4 cells, one per distinct SDK code path — the (level x type) matrix has only 3 independently-testable combos because the SDK forces line_number=0 for any PROBE config (see ADOT Python InstrumentationConfiguration.parse() and ADOT Java InstrumentationConfiguration.parse()); plus methodProbeException for throwable capture in the function wrapper. There is no lineBreakpointException because the line engine has no exception-capture machinery (line snapshots fire pre-execution and emit no throwable regardless of whether the line raises). Placeholders: \"$VAR\" -> os.environ['VAR'] as a string; \"$INT:VAR\" -> int(os.environ['VAR']).",

  "createLineBreakpoint": {
    "_comment": "Cell 1: line-level BREAKPOINT on http_call:134 (logger.info inside the try block). Captures locals at the snapshot point.",
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "Location": {
      "CodeLocation": {
        "Language": "Python",
        "FilePath": "/home/ec2-user/django_frontend_service/frontend_service_app/views.py",
        "LineNumber": 134,
        "CodeUnit": "frontend_service_app.views",
        "MethodName": "http_call"
      }
    },
    "CaptureConfiguration": {
      "CodeCapture": {
        "CaptureArguments": [],
        "CaptureLocals": ["status_code", "response", "url"],
        "CaptureReturn": false,
        "CaptureStackTrace": true,
        "CaptureLimits": { "MaxHits": 100, "MaxStringLength": 128, "MaxCollectionSize": 10, "MaxFieldsPerObject": 10 }
      }
    },
    "Description": "DI E2E line BREAKPOINT",
    "ExpiresAt": "$INT:EXPIRES_AT"
  },

  "createMethodProbe": {
    "_comment": "Cell 2: method-level PROBE on aws_sdk_call. Captures entry args + return value via the function wrapper.",
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "Location": {
      "CodeLocation": {
        "Language": "Python",
        "FilePath": "/home/ec2-user/django_frontend_service/frontend_service_app/views.py",
        "CodeUnit": "frontend_service_app.views",
        "MethodName": "aws_sdk_call"
      }
    },
    "CaptureConfiguration": {
      "CodeCapture": {
        "CaptureArguments": ["request"],
        "CaptureLocals": [],
        "CaptureReturn": true,
        "CaptureStackTrace": true,
        "CaptureLimits": { "MaxHits": 100, "MaxStringLength": 128, "MaxCollectionSize": 10, "MaxFieldsPerObject": 10 }
      }
    },
    "Description": "DI E2E method PROBE"
  },

  "createMethodBreakpoint": {
    "_comment": "Cell 3: method-level BREAKPOINT on downstream_service. Distinct SDK code path from method PROBE: BREAKPOINT has 24h TTL + max-hits semantics; PROBE is permanent. Validator pins instrumentation_type=BREAKPOINT.",
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "Location": {
      "CodeLocation": {
        "Language": "Python",
        "FilePath": "/home/ec2-user/django_frontend_service/frontend_service_app/views.py",
        "CodeUnit": "frontend_service_app.views",
        "MethodName": "downstream_service"
      }
    },
    "CaptureConfiguration": {
      "CodeCapture": {
        "CaptureArguments": ["request"],
        "CaptureLocals": [],
        "CaptureReturn": true,
        "CaptureStackTrace": true,
        "CaptureLimits": { "MaxHits": 100, "MaxStringLength": 128, "MaxCollectionSize": 10, "MaxFieldsPerObject": 10 }
      }
    },
    "Description": "DI E2E method BREAKPOINT",
    "ExpiresAt": "$INT:EXPIRES_AT"
  },

  "createMethodProbeException": {
    "_comment": "Cell 4: method-level PROBE on views.mysql, which raises KeyError uncaught when RDS_MYSQL_CLUSTER_PASSWORD is unset (DI test env never sets it). Validates throwable capture in the function wrapper's try/except/finally — body.captures.return.throwable.{type,message,stacktrace}.",
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "Location": {
      "CodeLocation": {
        "Language": "Python",
        "FilePath": "/home/ec2-user/django_frontend_service/frontend_service_app/views.py",
        "CodeUnit": "frontend_service_app.views",
        "MethodName": "mysql"
      }
    },
    "CaptureConfiguration": {
      "CodeCapture": {
        "CaptureArguments": ["request"],
        "CaptureLocals": [],
        "CaptureReturn": false,
        "CaptureStackTrace": true,
        "CaptureLimits": { "MaxHits": 100, "MaxStringLength": 128, "MaxCollectionSize": 10, "MaxFieldsPerObject": 10 }
      }
    },
    "Description": "DI E2E method PROBE exception"
  },

  "getLineBreakpoint": {
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "getMethodProbe": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "getMethodBreakpoint": {
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "getMethodProbeException": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "deleteLineBreakpoint": {
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "deleteMethodProbe": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "deleteMethodBreakpoint": {
    "InstrumentationType": "BREAKPOINT",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
  },

  "deleteMethodProbeException": {
    "InstrumentationType": "PROBE",
    "Service": "$SERVICE_NAME",
    "Environment": "$DI_ENVIRONMENT",
    "SignalType": "SNAPSHOT",
    "LocationIdentifier": { "LocationHash": "$LOCATION_HASH" }
