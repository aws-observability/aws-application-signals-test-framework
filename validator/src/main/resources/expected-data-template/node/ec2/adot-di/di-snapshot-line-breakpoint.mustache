[{
  "resource": {
    "attributes": {
      "service.name": "{{serviceName}}"
    }
  },
  "scope": {
    "name": "aws.dynamic_instrumentation"
  },
  "attributes": {
    "event.name": "aws.dynamic_instrumentation.snapshot",
    "aws.di.instrumentation_type": "BREAKPOINT",
    "aws.di.instrumentation_level": "line",
    "aws.di.location_hash": "{{locationHash}}",
    "aws.di.line_number": "86",
    "aws.di.file_path": "frontend-service/index.js",
    "aws.di.snapshot_id": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
  },
  "traceId": "^[0-9a-f]{32}$",
  "spanId": "^[0-9a-f]{16}$",
  "body": {
    "captures": {
      "lines": {
        "86": {
          "locals": {
            "options": {
              "type": "^Object$",
              "fields": {
                "hostname": {
                  "type": "^string$",
                  "value": "^www\\.amazon\\.com$"
                },
                "method": {
                  "type": "^string$",
                  "value": "^GET$"
                }
              }
            }
          }
        }
      }
    },
    "stack": [
      {
        "file_path": "^.*index\\.js$"
      }
    ]
  }
}]
